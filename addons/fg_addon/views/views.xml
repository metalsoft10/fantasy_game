<odoo>
  <data>
    <record id="fg_addon_res_partnerinherit_view_form" model="ir.ui.view">
            <field name="name">fg_addon.res.partner.inherit.view.form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
              <xpath expr="//field[@name='vat']" position="after">
                <field name="is_player"/>
                <field name="is_shop_user"/>
                <field name="current_active_subscription"/>
                <field name="subscription_plan_id"/>
              </xpath>
              <xpath expr="//page[@name='contact_addresses']" position="after">
                <page name="subscription_plan_usage" string="Player Usage">
                    <group>
                        <field name="subscription_usage_ids"/>
                    </group>
                </page>
              </xpath>


            </field>
    </record>
                
