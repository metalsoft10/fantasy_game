<odoo>
    <data>
        
        <template id="supscription_wrong_link">
                <t t-call="fg_addon.supscription_layout">
                    <t t-set="content">
                        <div class="row player_current_plan_details">
                            <div class="col-4">
                                <div class="card card-body">
                                    <div class="d-flex mb-4 align-items-center">
                                        <div class="flex-shrink-0">
                                            <i class="ri-error-warning-line display-6 text-danger"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-2">
                                            <h5 class="card-title mb-1">There Are An Error</h5>
                                            <p class="text-muted mb-0">Please Shere Error With Us</p>
                                        </div>
                                    </div>
                                    <h6 class="mb-1"><t t-out="error"/></h6>
                                    <p class="card-text text-muted"></p>
                                    
                                </div>
                            </div>
                            
                        </div>
                    </t>
                </t>
        </template>
        
        <template id="supscription_no_player">
                <t t-call="fg_addon.supscription_layout">
                    <t t-set="content">
                        <div class="row player_current_plan_details">
                            <div class="col-4">
                                <div class="card card-body">
                                    <div class="d-flex mb-4 align-items-center">
                                        <div class="flex-shrink-0">
                                            <i class="ri-error-warning-line display-6 text-danger"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-2">
                                            <h5 class="card-title mb-1">There Are An Error</h5>
                                            <p class="text-muted mb-0">Please Shere Error With Us</p>
                                        </div>
                                    </div>
                                    <h6 class="mb-1"><t t-out="error"/></h6>
                                    <p class="card-text text-muted"></p>
                                    
                                </div>
                            </div>
                            
                        </div>
                    </t>
                </t>
        </template>
        
        <template id="supscription_player">
                <t t-call="fg_addon.supscription_layout">
                    <t t-set="content">
                        <t t-if="subscription">
                        
                            <div  class="row player_current_plan_details" >
                                    <div class="col-lg-6">
                                        <div class="card pricing-box text-center">
                                            <div class="row g-0">
                                                <div class="col-lg-4">
                                                    <div class="card-body h-100">
                                                        <img t-att-src="player.player_qr_base64()" style="max-width: 128px;"></img>
                                                    </div>
                                                </div>
                                                <div class="col-lg-4">
                                                    <div class="card-body h-100">
                                                        <div>
                                                            <h5 class="mb-1"><t t-out="subscription.name.name"/></h5>
                                                            <p class="text-muted">Current Plan</p>
                                                        </div>

                                                        <div class="py-4">
                                                            
                                                            <h2><sup><small>Sar</small></sup><t t-out="subscription.name.price"/> <span class="fs-13 text-muted"> </span></h2>
                                                        </div>

                                                        <div class="text-center plan-btn mt-2">
                                                            
                                                            
                                                            
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-lg-4">
                                                    <div class="card-body border-start mt-4 mt-lg-0">
                                                        <div class="card-header bg-light">
                                                            <h5 class="fs-15 mb-0">Plan Features:</h5>
                                                        </div>
                                                        <div class="card-body pb-0">
                                                            <ul class="list-unstyled vstack gap-3 mb-0">
                                                                <li>Hours Per Day : <span class="text-success fw-semibold"><t t-out="subscription.name.hours"/></span></li>
                                                                <li>Start : <span class="text-success fw-semibold"><t t-out="subscription.start"/></span>
                                                                </li>
                                                                <li>End : <span class="text-success fw-semibold"><t t-out="subscription.end"/></span></li>
                                                                
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-xl-12">
                                        <div class="card crm-widget">
                                            <div class="card-body p-0">
                                                <div class="row row-cols-md-3 row-cols-1">
                                                    <div class="col col-lg border-end">
                                                        <div class="py-4 px-3">
                                                            <h5 class="text-muted text-uppercase fs-13">Today Usage
                                                            </h5>
                                                            <div class="d-flex align-items-center">
                                                                <div class="flex-shrink-0">
                                                                    <i class="ri-exchange-funds-line display-6 text-info"></i>
                                                                </div>
                                                                <div class="flex-grow-1 ms-3">
                                                                    <h2 class="mb-0"><span class="counter-value" t-att-data-target="subscription.today_usage()"><t t-out="subscription.today_usage()"/></span></h2>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div><!-- end col -->
                                                    <div class="col col-lg border-end">
                                                        <div class="mt-3 mt-md-0 py-4 px-3">
                                                            <h5 class="text-muted text-uppercase fs-13">Today Remaining 
                                                            </h5>
                                                            <div class="d-flex align-items-center">
                                                                <div class="flex-shrink-0">
                                                                    <i class="ri-timer-line display-6 text-primary"></i>
                                                                </div>
                                                                <div class="flex-grow-1 ms-3">
                                                                    <h2 class="mb-0"><span class="counter-value" t-att-data-target="subscription.today_remaining()"><t t-out="subscription.today_remaining()"/></span></h2>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div><!-- end col -->
                                                    <div class="col col-lg border-end">
                                                        <div class="mt-3 mt-md-0 py-4 px-3">
                                                            <h5 class="text-muted text-uppercase fs-13">Plan Usage 
                                                            </h5>
                                                            <div class="d-flex align-items-center">
                                                                <div class="flex-shrink-0">
                                                                    <i class="ri-exchange-funds-line display-6 text-info"></i>
                                                                </div>
                                                                <div class="flex-grow-1 ms-3">
                                                                    <h2 class="mb-0"><span class="counter-value" t-att-data-target="subscription.plan_usage()"><t t-out="subscription.plan_usage()"/></span></h2>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div><!-- end col -->
                                                    <div class="col col-lg border-end">
                                                        <div class="mt-3 mt-lg-0 py-4 px-3">
                                                            <h5 class="text-muted text-uppercase fs-13">Plan Remaining 
                                                            </h5>
                                                            <div class="d-flex align-items-center">
                                                                <div class="flex-shrink-0">
                                                                    <i class="ri-timer-flash-line display-6 text-primary"></i>
                                                                </div>
                                                                <div class="flex-grow-1 ms-3">
                                                                    <h2 class="mb-0"><span class="counter-value" t-att-data-target="subscription.plan_remaining()"><t t-out="subscription.plan_remaining()"/></span></h2>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div><!-- end col -->
                                                    
                                                </div><!-- end row -->
                                            </div><!-- end card body -->
                                        </div><!-- end card -->
                                    </div><!-- end col -->
                                </div>
                                <div class="row">
                                    <div class="col-xl-12">
                                        <div class="card">
                                            <div class="card-body p-0">
                                                <div class="table-responsive mt-4 mt-xl-0">
                                                    <table class="table table-hover table-striped align-middle table-nowrap mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th scope="col">Id</th>
                                                                <th scope="col">Start</th>
                                                                <th scope="col">End</th>
                                                                <th scope="col">duration</th>
                                                                <th scope="col">Status</th>
                                                                
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                        
                                                            <tr t-foreach="subscription.subscription_usage_ids.sorted(key='start', reverse=True)" t-as="usage">
                                                                <th scope="row"><t t-out="usage.id"/></th>
                                                                <td><t t-out="usage.start"/></td>
                                                                <td><t t-out="usage.end"/></td>
                                                                <td><t t-out="subscription._format_hours(usage.duration)"/></td>
                                                                <td><i t-if="usage.status == 'running'" class="mdi mdi-dots-circle mdi-spin text-success fs-5 me-1"></i>  <t t-out="usage.status"/></td>
                                                                
                                                            </tr>
                                                            
                                                        </tbody>
                                                    </table>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                        </t>
                        <t t-else="">
                            <div class="row player_current_plan_details">
                                <div class="col-4">
                                    <div class="card card-body">
                                        <div class="d-flex mb-4 align-items-center">
                                            <div class="flex-grow-1">
                                                <i class="ri-error-warning-line display-6 text-warning"></i>
                                            </div>
                                            <div class="flex-grow-1 ms-2">
                                                <h5 class="card-title mb-1">There Are No Active Plan</h5>
                                                <p class="text-muted mb-0">Please Shere Error With Us</p>
                                            </div>
                                            <div class="flex-grow-1 ms-2">
                                                <img t-att-src="player.player_qr_base64()" style="max-width: 128px;"></img>
                                            </div>
                                        </div>
                                        <h6 class="mb-1">You Dont Have Any Active Plan</h6>
                                        <p class="card-text text-muted"></p>
                                        
                                    </div>
                                </div>
                                

                                
                            </div>

                        </t>
                    </t>
                </t>
        </template>
    </data>
</odoo>