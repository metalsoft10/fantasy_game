            <!-- JAVASCRIPT -->
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>


            <script>
                $(function() {
                let __step = 1;

                function showStep(n) {
                    $('.1_step').addClass('hidden');
                    $(`.1_step[data-step=${n}]`).removeClass('hidden').addClass('w_fade');
                    $('.prev').toggle(n &gt; 1);
                    $('.next').text(n === 5 ? 'Finish' : 'Next');
                }

                $('.next').click(function() {
                    if (__step &lt; 5) {
                    __step++;
                    showStep(__step);
                    } else {
                    $('#steps_modal').fadeOut(600);
                    }
                });

                $('.prev').click(function() {
                    if (__step &gt; 1) {
                    __step--;
                    showStep(__step);
                    }
                });

                showStep(__step);
                });
            </script>            
