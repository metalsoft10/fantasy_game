<odoo>
  <data>

    <record id="main_pharma.view_ai_orderpoint_form" model="ir.ui.view">
            <field name="name">ai.orderpoint.form</field>
            <field name="model">ai.orderpoint</field>
            <field name="arch" type="xml">
                <form string="Ai Orderpoint">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="state"/>
                            <field name="error_message"/>
                            <field name="processed_count"/>
                            <field name="orderpoint_ids" string="">
                                <list>
                                    <field name="product_id"/>
                                    <field name="current_on_hand"/>
                                    <field name="min_reorder"/>
                                </list>
                            </field>
                            <field name="ai_response"/>
                            
                        </group>
                        
                    </sheet>
                    
                </form>
            </field>
    </record>
    <record model="ir.actions.act_window" id="main_pharma.ai_orderpoint_action_window">
      <field name="name">ai.orderpoint.window</field>
      <field name="res_model">ai.orderpoint</field>
      <field name="view_mode">list,form</field>
    </record>
    <!-- Top menu item -->
    <menuitem name="Ai Order Point" id="main_pharma.ai_orderpoint_menu_root"/>
    <menuitem name="Ai Order Point List" id="main_pharma.menu_orderpoint_list" parent="main_pharma.ai_orderpoint_menu_root"
              action="main_pharma.ai_orderpoint_action_window"/>
